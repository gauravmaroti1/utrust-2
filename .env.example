# ===== U TRUST 2.0 Environment Variables =====
# PostgreSQL connection string. On Railway, add the PostgreSQL plugin and this is
# auto-injected as DATABASE_URL. Locally, point to your own Postgres instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/utrust

# Secret used to sign JWT access tokens. Generate a long random string.
JWT_SECRET=change-this-to-a-long-random-secret-string

# Port the server listens on. Railway injects PORT automatically.
PORT=8080

# Default Super Admin credentials created on first boot (change after first login).
ADMIN_EMAIL=admin@prakashautohub.com
ADMIN_PASSWORD=Prakash@123

# Set to "true" to auto-create schema and seed demo data on boot when DB is empty.
AUTO_MIGRATE=true
